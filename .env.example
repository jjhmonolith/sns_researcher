# OpenAI API Key
OPENAI_API_KEY=sk-your-api-key-here

# Models
MODEL_FAST=gpt-5.4-nano        # 구동용 (관련성 판단, 요약)
MODEL_POWERFUL=gpt-5.4          # 지식 합성용

# LinkedIn Search Keywords (comma-separated)
SEARCH_KEYWORDS=기업 AX,AI 트랜스포메이션,AI Transformation,enterprise AI,디지털 전환,AX 전략

# Relevance threshold (0-100)
RELEVANCE_THRESHOLD=40

# Crawling settings
SCROLL_DELAY_MIN=30             # 최소 대기 시간 (초)
SCROLL_DELAY_MAX=120            # 최대 대기 시간 (초)
MAX_POSTS_PER_SESSION=200       # 세션당 최대 수집 포스트
SYNTHESIS_INTERVAL_POSTS=20     # N개 포스트마다 합성
SYNTHESIS_INTERVAL_HOURS=6      # N시간마다 합성

# Dashboard
DASHBOARD_PORT=8501
DASHBOARD_HOST=0.0.0.0
